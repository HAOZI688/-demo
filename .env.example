# 爆款猎人 Demo — 运行时配置
# 此文件是模板，复制为 .env 后填值
# 注意：生产环境应使用 .env.runtime 而非 .env（由部署脚本生成）

# LLM 模式开关
# 0 = mock 模式（默认，零依赖）
# 1 = 启用真实 LLM（需要下面 4 个 TOKEN_*；当前 demo 第一轮未实现 USE_LLM=1 路径，将安全 fallback 到 mock）
USE_LLM=0

# LLM API 凭据（仅 USE_LLM=1 时需要；当前版本可安全留空）
TOKEN_API_BASE=
TOKEN_API_KEY=
TOKEN_MODEL_NAME=
